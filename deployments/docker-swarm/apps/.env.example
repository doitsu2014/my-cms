# ============================================
# .env (my-cms apps stack)
# Variables consumed by apps/docker-compose.yaml
# Copy to apps/.env (gitignored) and edit secrets.
# Shared values must be kept in sync with ../supabase/.env.example
# (look for the markers above each shared value).
#
# Traefik-related routing vars (STUDIO_BASIC_AUTH_USERS, CMS_SUPABASE_ORIGIN)
# live in ../traefik/.env — they are NOT consumed here. CMS_HOST and
# CMS_ADMIN_ORIGIN are duplicated across apps/.env (compose labels) and
# traefik/.env (dynamic config).
# ============================================

# ---------- Shared secrets ----------
# KEEP IN SYNC with ../supabase/.env.example
POSTGRES_PASSWORD=devpassword
# KEEP IN SYNC with ../supabase/.env.example
JWT_SECRET=dev-jwt-secret-at-least-32-chars-long!!
# KEEP IN SYNC with ../supabase/.env.example
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..PKzvDajcmVqOY_xoRftRUSrLgcw_0RQYAuIcn9nrE8E
# KEEP IN SYNC with ../supabase/.env.example
# Kong's request-transformer rewrites Authorization as "Bearer $(headers.apikey)".
# The backend MUST send BOTH "Authorization" and "apikey" headers for Storage
# to work through Kong.  See supabase_storage.rs — every HTTP method adds
# .bearer_auth(auth_key).header("apikey", auth_key).
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..0tP4pFIn6y7ZZKsTlcVzTDeb8tdIB0K68i5vUh3FDbs
# KEEP IN SYNC with ../supabase/.env.example
SUPABASE_PUBLIC_URL=https://supabase-api.ducth.dev
# KEEP IN SYNC with ../supabase/.env.example
SITE_URL=http://localhost:3002
# KEEP IN SYNC with ../supabase/.env.example
API_EXTERNAL_URL=http://localhost:8989

# ---------- Database ----------
DATABASE_URL=postgresql://supabase_admin:${POSTGRES_PASSWORD}@db:5432/postgres
DATABASE_SCHEMA=public

# ---------- API ----------
HOST=0.0.0.0
PORT=8989
RUST_LOG=info
MAX_BODY_LENGTH=10485760

# ---------- Supabase (apps-side) ----------
SUPABASE_URL=http://localhost:8000
# Docker-network URL the API container uses to reach Kong.
# Falls back to SUPABASE_URL if unset. The frontend and host-side
# scripts (reset-supabase.sh, cargo run) keep using SUPABASE_URL.
SUPABASE_INTERNAL_URL=http://supabase-kong:8000
SUPABASE_ANON_KEY=${ANON_KEY}
SUPABASE_SERVICE_ROLE_KEY=${SERVICE_ROLE_KEY}
SUPABASE_JWT_SECRET=${JWT_SECRET}
AUTHORIZATION_AUDIENCE=authenticated

# ---------- Tracing ----------
ENABLED_OTLP_EXPORTER=true
OTEL_SERVICE_NAME=my-cms-headless-api
SERVICE_NAME=my-cms-headless-api
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://jaeger:4317
OTEL_TRACES_SAMPLER=always_on

# ---------- OpenAI (optional) ----------
OPENAI_API_KEY=

# ---------- Media ----------
MEDIA_BASE_URL=http://localhost:8989

# ---------- Routing (consumed by Traefik labels in docker-compose.yaml) ----------
# CMS_HOST          — Host() rule for the api/admin Traefik routers
# CMS_ADMIN_ORIGIN  — CORS origin allowed for the admin frontend
# (STUDIO_BASIC_AUTH_USERS and CMS_SUPABASE_ORIGIN live in ../traefik/.env)
CMS_HOST=localhost
CMS_ADMIN_ORIGIN=http://localhost:3002

# ---------- Frontend (rsbuild build-time) ----------
# Mode A (subdomain deploy): PUBLIC_REST_API_URL is the bare API origin.
# The /api prefix is only used in single-domain deploys where the gateway
# strips it before proxying. See apps/web/.env.example for the full
# explanation. Backend media upload route is POST /media.
PUBLIC_SUPABASE_URL=http://localhost:8000
PUBLIC_SUPABASE_ANON_KEY=${ANON_KEY}
PUBLIC_GRAPHQL_API_URL=http://localhost:8989/graphql
PUBLIC_GRAPHQL_CACHE_API_URL=http://localhost:8989/graphql
PUBLIC_REST_API_URL=http://localhost:8989
PUBLIC_MEDIA_UPLOAD_API_URL=http://localhost:8989/media
