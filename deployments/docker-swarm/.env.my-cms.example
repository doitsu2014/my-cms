# ============================================
# .env.my-cms.example
# Variables consumed by docker-compose.my-cms.yaml
# Copy to .env.my-cms and edit secrets.
# Shared values must be kept in sync with .env.supabase.example
# (look for the markers above each shared value)
# ============================================

# ---------- Shared secrets ----------
# KEEP IN SYNC with .env.supabase.example
POSTGRES_PASSWORD=devpassword
# KEEP IN SYNC with .env.supabase.example
JWT_SECRET=dev-jwt-secret-at-least-32-chars-long!!
# KEEP IN SYNC with .env.supabase.example
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..PKzvDajcmVqOY_xoRftRUSrLgcw_0RQYAuIcn9nrE8E
# KEEP IN SYNC with .env.supabase.example
SERVICE_ROLE_KEY=devkey
# KEEP IN SYNC with .env.supabase.example
SUPABASE_PUBLIC_URL=http://localhost:8000
# KEEP IN SYNC with .env.supabase.example
SITE_URL=http://localhost:3002
# KEEP IN SYNC with .env.supabase.example
API_EXTERNAL_URL=http://localhost:8989

# ---------- Database ----------
DATABASE_URL=postgresql://supabase_admin:${POSTGRES_PASSWORD}@db:5432/postgres
DATABASE_SCHEMA=public

# ---------- API ----------
HOST=0.0.0.0
PORT=8989
RUST_LOG=info
MAX_BODY_LENGTH=10485760

# ---------- Supabase (apps-side) ----------
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=${ANON_KEY}
SUPABASE_SERVICE_ROLE_KEY=${SERVICE_ROLE_KEY}
SUPABASE_JWT_SECRET=${JWT_SECRET}
SUPABASE_STORAGE_BUCKET=media
AUTHORIZATION_AUDIENCE=authenticated

# ---------- Tracing ----------
ENABLED_OTLP_EXPORTER=true
OTEL_SERVICE_NAME=my-cms-headless-api
SERVICE_NAME=my-cms-headless-api
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://jaeger:4317
OTEL_TRACES_SAMPLER=always_on

# ---------- OpenAI (optional) ----------
OPENAI_API_KEY=

# ---------- Media ----------
MEDIA_BASE_URL=http://localhost:8989

# ---------- Traefik Basic Auth ----------
# Generate a new hash: npx htpasswd-js -b -n admin "your-password"
STUDIO_BASIC_AUTH_USERS=admin:$2y$05$5dcJrN0MmpA1xPeFnCgGfeGXpiHtqCVSRxBvYP8NOXgoRaS3NoSoW

# ---------- Frontend (rsbuild build-time) ----------
PUBLIC_SUPABASE_URL=http://localhost:8000
PUBLIC_SUPABASE_ANON_KEY=${ANON_KEY}
PUBLIC_GRAPHQL_API_URL=http://localhost:8989/graphql
PUBLIC_GRAPHQL_CACHE_API_URL=http://localhost:8989/graphql
PUBLIC_REST_API_URL=http://localhost:8989/api
PUBLIC_MEDIA_UPLOAD_API_URL=http://localhost:8989/api/media/upload
