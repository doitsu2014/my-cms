# ============================================
# .env (Traefik proxy stack)
# Variables consumed by traefik/docker-compose.yaml
# AND traefik/dynamic/my-cms.yml (the dynamic routing config).
#
# Copy this file to traefik/.env next to docker-compose.yaml and edit.
# ============================================

# ---------- Routing ----------
# CMS_HOST             — Host() rule for all four Traefik routers
#                         (admin, api, studio, supabase-api)
# CMS_ADMIN_ORIGIN     — CORS origin allowed for the admin frontend
# CMS_SUPABASE_ORIGIN  — CORS origin allowed for supabase-api / Kong
CMS_HOST=localhost
CMS_ADMIN_ORIGIN=http://localhost:3002
CMS_SUPABASE_ORIGIN=http://localhost

# ---------- Basic Auth (Supabase Studio) ----------
# Generate a new hash: npx htpasswd-js -b -n admin "your-password"
# Format: user:$apr1$... or user:$2y$...
STUDIO_BASIC_AUTH_USERS=admin:$2y$05$5dcJrN0MmpA1xPeFnCgGfeGXpiHtqCVSRxBvYP8NOXgoRaS3NoSoW