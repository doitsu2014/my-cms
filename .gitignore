# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

dist
.dioxus
.DS_Store

secret.env
.env.local
development.env
uat.env
production.env

deployments/charts/**/secret.values.yaml

.idea/
**/test-llvm-reports
lcov.info

node_modules
dist

# Docker compose
.env
docker-compose.override.yml
.pnpm-store

# Local dev env files (split per compose folder, see deployments/docker-swarm/README.md)
deployments/docker-swarm/*/.env

deployments/docker-swarm/supabase/volumes/db/data/*
deployments/docker-swarm/supabase/volumes/secrets/*

# Allow the example env files (one per component folder)
!deployments/docker-swarm/*/.env.example