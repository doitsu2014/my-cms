# Normalize line endings for shell scripts and Docker/build files
# to LF so they run correctly inside Linux containers.
*.sh             text eol=lf
*.bash           text eol=lf
Dockerfile       text eol=lf
Dockerfile.*     text eol=lf
*.conf           text eol=lf
*.tmpl           text eol=lf
*.template       text eol=lf
