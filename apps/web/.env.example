# apps/web environment variables — LOCAL DEV TEMPLATE
#
# Copy this file to .env (or .env.local) and fill in the values for your
# environment. The PUBLIC_* variables are consumed at build time by rsbuild
# (see apps/web/rsbuild.config.ts → loadEnv() + source.define) and exposed to
# the client bundle via import.meta.env.PUBLIC_*. See apps/web/src/env.d.ts
# for the typed contract.
#
# Mirrors the layout of deployments/docker-swarm/apps/.env.example for the
# local Compose stack (API on :8989, Supabase Kong on :8000).

# ---------- Supabase ----------
# URL of the Supabase gateway (Kong). For local Compose dev this is
# http://localhost:8000. For production point at your project's URL
# (e.g. https://<project-ref>.supabase.co or a custom domain behind Traefik).
#
# The frontend always uses PUBLIC_SUPABASE_URL (browser-direct GoTrue
# auth). The BACKEND container has its own SUPABASE_INTERNAL_URL env
# var (see deployments/docker-swarm/apps/.env.example) that resolves
# to http://supabase-kong:8000 on the shared Docker network — the
# frontend does not need a separate internal URL.
PUBLIC_SUPABASE_URL=http://localhost:8000

# Supabase anon key — the publishable JWT sent from the browser.
# For local dev, reuse the ANON_KEY value from
# deployments/docker-swarm/supabase/.env (an HS256 JWT signed with the
# local JWT_SECRET). For production, use the anon key from your Supabase
# project's API settings — never the service_role key.
PUBLIC_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key

# ---------- my-cms Backend API ----------
# GraphQL endpoint (POST). The backend exposes /graphql/immutable and
# /graphql/mutable; the helper resolves the URL as configured here.
PUBLIC_GRAPHQL_API_URL=http://localhost:8989/graphql

# Optional GraphQL cache endpoint (CDN/read-replica). Leave unset to fall
# back to PUBLIC_GRAPHQL_API_URL.
PUBLIC_GRAPHQL_CACHE_API_URL=http://localhost:8989/graphql

# REST API base URL. Mode A (subdomain deploy): bare origin, e.g.
# http://localhost:8989. Mode B (single-domain deploy): leave empty and the
# helper prepends /api. See apps/web/src/config/api.config.ts for the
# resolution logic.
PUBLIC_REST_API_URL=http://localhost:8989

# Media upload endpoint. The backend route is POST /media. Leave empty to
# derive as <PUBLIC_REST_API_URL>/media (Mode A) or /media (Mode B).
PUBLIC_MEDIA_UPLOAD_API_URL=http://localhost:8989/media