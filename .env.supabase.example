# ============================================
# .env.supabase.example
# Variables consumed by docker-compose.supabase.yaml
# Copy to .env.supabase and edit secrets.
# Shared values must be kept in sync with .env.my-cms.example
# (look for the markers above each shared value)
# ============================================

# ---------- Shared secrets ----------
# KEEP IN SYNC with .env.my-cms.example
POSTGRES_PASSWORD=devpassword
# KEEP IN SYNC with .env.my-cms.example
JWT_SECRET=dev-jwt-secret-at-least-32-chars-long!!
# KEEP IN SYNC with .env.my-cms.example
# These are HS256 JWTs signed with JWT_SECRET above. GoTrue validates them on
# every API call. Generate with: bash scripts/generate-jwt.sh
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..PKzvDajcmVqOY_xoRftRUSrLgcw_0RQYAuIcn9nrE8E
# KEEP IN SYNC with .env.my-cms.example
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..0tP4pFIn6y7ZZKsTlcVzTDeb8tdIB0K68i5vUh3FDbs
# KEEP IN SYNC with .env.my-cms.example
SUPABASE_PUBLIC_URL=http://localhost:8001
# KEEP IN SYNC with .env.my-cms.example
SITE_URL=http://localhost:3002
# KEEP IN SYNC with .env.my-cms.example
API_EXTERNAL_URL=http://localhost:8989

# ---------- Postgres ----------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres

# ---------- Dashboard ----------
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin

# ---------- Studio ----------
STUDIO_DEFAULT_ORGANIZATION="My CMS"
STUDIO_DEFAULT_PROJECT=my-cms-local

# ---------- Kong ----------
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# ---------- PostgREST ----------
PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000

# ---------- GoTrue / Auth ----------
JWT_EXPIRY=3600

# ---------- SMTP (Mailpit) ----------
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME="My CMS"

# ---------- Storage ----------
STORAGE_TENANT_ID=stub
GLOBAL_S3_BUCKET=stub
REGION=local
S3_PROTOCOL_ACCESS_KEY_ID=
S3_PROTOCOL_ACCESS_KEY_SECRET=

# ---------- Supavisor ----------
POOLER_TENANT_ID=your-tenant-id
POOLER_DEFAULT_POOL_SIZE=15
POOLER_MAX_CLIENT_CONN=100
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DB_POOL_SIZE=5

# ---------- Required Supabase secrets ----------
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1u2oq
VAULT_ENC_KEY=your-32-character-encryption-key
PG_META_CRYPTO_KEY=your-encryption-key-32-chars-min

# ---------- imgproxy ----------
IMGPROXY_AUTO_WEBP=true
