# frontend/Dockerfile.dev
# Development server for the React admin panel (rsbuild).

FROM node:22-alpine

WORKDIR /app

COPY package.json pnpm-lock.yaml ./

RUN corepack enable && pnpm install --frozen-lockfile

COPY . .

EXPOSE 3002

CMD ["pnpm", "run", "dev", "--port", "3002", "--host", "0.0.0.0"]
